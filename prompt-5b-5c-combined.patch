+async function getActiveProductionExecutionSessionsSafe() {
+  const client = ensureClient();
+
+  if (!client) {
+    return {
+      tableAvailable: false,
+      runningSessions: 0,
+      activeSessionLineIds: new Set<string>(),
+    };
+  }
+
+  const { data, error } = await client
+    .from("production_execution_sessions")
+    .select("line_id, status, ended_at")
+    .is("ended_at", null);
+
+  if (error) {
+    return {
+      tableAvailable: false,
+      runningSessions: 0,
+      activeSessionLineIds: new Set<string>(),
+    };
+  }
+
+  const rows = (data ?? []) as Array<{ line_id?: string | null; status?: string | null }>;
+
+  return {
+    tableAvailable: true,
+    runningSessions: rows.filter((row) => row.status !== "CLOSED").length,
+    activeSessionLineIds: new Set(
+      rows
+        .map((row) => row.line_id)
+        .filter((lineId): lineId is string => Boolean(lineId)),
+    ),
+  };
+}
+
+async function hasReadableTableSafe(tableName: string) {
+  const client = ensureClient();
+
+  if (!client) {
+    return false;
+  }
+
+  const { error } = await client.from(tableName).select("id", { head: true }).limit(1);
+  return !error;
+}
+
+function productionExecutionLineFromLine(
+  line: LineCard,
+  group: ProductionGroup | undefined,
+  activeSessionLineIds: Set<string>,
+): ProductionExecutionLine {
+  const hasActiveExecutionSession = activeSessionLineIds.has(line.id);
+  const isGhostOrInactiveGroup =
+    line.groupCode === "G-11" || group?.is_ghost === true || group?.is_active === false;
+  const assignmentStatus =
+    line.activeContext !== null
+      ? "ASSIGNED"
+      : line.isActive && !line.isSpecial && !isGhostOrInactiveGroup
+        ? "AVAILABLE"
+        : "NOT_ASSIGNABLE";
+  const blockers: string[] = [];
+
+  if (!line.activeContext) {
+    blockers.push("No active context");
+  }
+
+  if (!line.isActive) {
+    blockers.push("Inactive line");
+  }
+
+  if (line.isSpecial) {
+    blockers.push("Special line");
+  }
+
+  if (isGhostOrInactiveGroup) {
+    blockers.push("Ghost or inactive line group");
+  }
+
+  if (hasActiveExecutionSession) {
+    blockers.push("Already running");
+  }
+
+  if (line.activeContext && line.status !== "WAITING_FOR_DATA") {
+    blockers.push(`Operational status is ${line.status.replaceAll("_", " ")}`);
+  }
+
+  const canStartProductionDerived =
+    line.activeContext !== null &&
+    line.status === "WAITING_FOR_DATA" &&
+    line.isActive &&
+    !line.isSpecial &&
+    !isGhostOrInactiveGroup &&
+    !hasActiveExecutionSession;
+
+  return {
+    ...line,
+    assignmentStatus,
+    executionReadinessStatus: getExecutionReadinessStatus(
+      line,
+      canStartProductionDerived,
+    ),
+    executionReadinessBlockers: blockers,
+    hasActiveExecutionSession,
+    canStartProductionDerived,
+  };
+}
+
+function getExecutionReadinessStatus(
+  line: LineCard,
+  canStartProductionDerived: boolean,
+) {
+  if (line.status === "RUNNING") {
+    return "RUNNING";
+  }
+
+  if (line.status === "STOPPED") {
+    return "PAUSED_STOPPED";
+  }
+
+  if (line.status === "QUALITY_HOLD") {
+    return "QUALITY_HOLD";
+  }
+
+  if (line.status === "NO_FEEDING") {
+    return "NO_FEEDING";
+  }
+
+  if (!line.activeContext) {
+    return "NOT_STARTED";
+  }
+
+  if (canStartProductionDerived) {
+    return "READY_TO_START";
+  }
+
+  return "WAITING_FOR_EXECUTION_DATA";
+}
